# Destiny Codex configuration
# Copy this file to ".env" and fill in your values.

# Required: your Bungie.net API key from https://www.bungie.net/en/Application
BUNGIE_API_KEY=

# Optional: manifest language (default: en)
# D2_LANGUAGE=en

# Optional: cache directory for the SQLite DB (default: ~/.d2manifest)
# D2_CACHE_DIR=
